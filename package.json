{
  "name": "gh-clear-artifacts",
  "version": "1.0.0",
  "description": "GitHub Action to delete workflow artifacts in a repository, optionally scoped by branch, name, or age.",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "lint": "eslint .",
    "test": "jest",
    "all": "npm run build && npm run lint && npm run test"
  },
  "keywords": [
    "actions",
    "github",
    "artifacts",
    "cleanup"
  ],
  "author": "Colin Rundel",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
